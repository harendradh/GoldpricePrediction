# ChangePilot Studio · backend environment template
# Copy to backend/.env and fill in the real values.

# ── Databricks Claude (Model Serving) ─────────────────────────
DATABRICKS_HOST=https://adb-xxxxxxxxxxxxxxxx.azuredatabricks.net
DATABRICKS_TOKEN=dapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATABRICKS_MODEL_SERVING_ENDPOINT=databricks-claude-3-7-sonnet
DATABRICKS_MODEL_FALLBACKS=databricks-claude-3-5-sonnet,databricks-claude-3-5-haiku

# ── GitHub ────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string

# ── Persistence ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./atlas.db

# ── Review behavior ───────────────────────────────────────────
ATLAS_AUTO_POST_THRESHOLD=80
ATLAS_BLOCK_ON_BLOCKER=true
ATLAS_RUN_ON_DRAFT_PRS=false

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── Notifications (optional) ──────────────────────────────────
SLACK_WEBHOOK_URL=
